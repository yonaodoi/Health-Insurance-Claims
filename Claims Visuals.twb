      <aliases enabled='yes' />
      <column caption='Top Provider Claim Count Filter' datatype='boolean' name='[Calculation_0253218987859973]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(COUNT([ProviderID]),&apos;DESC&apos;)&lt;= [Calculation_0253218987859973]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Claim Count' datatype='integer' name='[Calculation_0253218991247366]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ClaimID])' />
      </column>
      <column caption='Emergency Claim per patient' datatype='integer' name='[Calculation_0253219007643655]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [PatientID] : COUNT(IF [ClaimType] = &apos;Emergency&apos; THEN [ClaimID] END&#13;&#10;) }' />
      </column>
      <column caption='Flag patients above threshold' datatype='integer' name='[Calculation_0253219020386312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF { FIXED [PatientID] : COUNT(&#13;&#10;        IF [ClaimType] = &apos;Emergency&apos; THEN [ClaimID] END&#13;&#10;    ) } &gt; 3&#13;&#10;AND { FIXED [PatientID] : SUM(&#13;&#10;        IF [ClaimType] = &apos;Emergency&apos; THEN [ClaimAmount] END&#13;&#10;    ) } &gt; 50000&#13;&#10;THEN 1 ELSE 0 END' />
      </column>
      <column caption='Denial to Approval Ratio' datatype='real' name='[Calculation_0253219023720457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [ClaimStatus] = &apos;Denied&apos; THEN 1 ELSE 0 END) &#13;&#10;/&#13;&#10;SUM(IF [ClaimStatus] = &apos;Approved&apos; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1241404985065472]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PatientAge] &gt;= 0 AND [PatientAge]&lt;= 29 THEN &apos;Young &lt;30&apos;&#13;&#10;ELSEIF [PatientAge] &gt;= 30 AND [PatientAge]&lt;= 59 THEN &apos;Middle_Age 30-60&apos;&#13;&#10;ELSEIF  [PatientAge] &gt;= 60 AND [PatientAge]&lt;= 99 THEN &apos;Senior 60+&apos;&#13;&#10;END' />
      </column>
      <column aggregation='CountD' caption='IncomeBracket' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1241404987092993]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PatientIncome] &gt;= 20000 AND [PatientIncome] &lt;= 50000 THEN &apos;Low_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 50001 AND [PatientIncome] &lt;= 100000 THEN &apos;Middle_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 100001 AND [PatientIncome] &lt;= 150000 THEN &apos;High_Income&apos;&#13;&#10;END' />
      </column>
      <column caption='Approval Rate' datatype='real' name='[Calculation_1241405013393410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [ClaimStatus] = &apos;Approved&apos; THEN 1 ELSE 0 END)/ COUNT([ClaimStatus]) * 100' />
      </column>
      <column caption='Denial Rate' datatype='real' name='[Calculation_1241405014687747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [ClaimStatus] = &apos;Denied&apos; THEN 1 ELSE 0 END)*100 / COUNT([ClaimID])' />
      </column>
