    <worksheet name='Qtn 3: Patient Demographics'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000'>Approval Rate across Gender, Income Bracket, &amp; Employment Status</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='enhanced_health_insurance_claims' name='federated.0q41bvh03h9eb41fq89sx0d0920t' />
          </datasources>
          <datasource-dependencies datasource='federated.0q41bvh03h9eb41fq89sx0d0920t'>
            <column aggregation='CountD' caption='IncomeBracket' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1241404987092993]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PatientIncome] &gt;= 20000 AND [PatientIncome] &lt;= 50000 THEN &apos;Low_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 50001 AND [PatientIncome] &lt;= 100000 THEN &apos;Middle_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 100001 AND [PatientIncome] &lt;= 150000 THEN &apos;High_Income&apos;&#13;&#10;END' />
            </column>
            <column caption='Approval Rate' datatype='real' name='[Calculation_1241405013393410]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [ClaimStatus] = &apos;Approved&apos; THEN 1 ELSE 0 END)/ COUNT([ClaimStatus]) * 100' />
            </column>
            <column caption='Claim Status' datatype='string' name='[ClaimStatus]' role='dimension' type='nominal' />
            <column caption='Patient Employment Status' datatype='string' name='[PatientEmploymentStatus]' role='dimension' type='nominal' />
            <column caption='Patient Gender' datatype='string' name='[PatientGender]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Patient Income' datatype='real' name='[PatientIncome]' role='dimension' type='ordinal' />
            <column caption='Provider Specialty' datatype='string' name='[ProviderSpecialty]' role='dimension' type='nominal' />
