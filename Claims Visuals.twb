    <worksheet name='Q2: average claim amount and approval rate by patient age group?'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontsize='10'>Average claim amount and approval rate by patient age group</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='enhanced_health_insurance_claims' name='federated.0q41bvh03h9eb41fq89sx0d0920t' />
