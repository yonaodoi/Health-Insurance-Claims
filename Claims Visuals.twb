          <datasource-dependencies datasource='federated.0q41bvh03h9eb41fq89sx0d0920t'>
            <column caption='Age Group' datatype='string' name='[Calculation_1241404985065472]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PatientAge] &gt;= 0 AND [PatientAge]&lt;= 29 THEN &apos;Young &lt;30&apos;&#13;&#10;ELSEIF [PatientAge] &gt;= 30 AND [PatientAge]&lt;= 59 THEN &apos;Middle_Age 30-60&apos;&#13;&#10;ELSEIF  [PatientAge] &gt;= 60 AND [PatientAge]&lt;= 99 THEN &apos;Senior 60+&apos;&#13;&#10;END' />
            </column>
            <column aggregation='CountD' caption='IncomeBracket' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_1241404987092993]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PatientIncome] &gt;= 20000 AND [PatientIncome] &lt;= 50000 THEN &apos;Low_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 50001 AND [PatientIncome] &lt;= 100000 THEN &apos;Middle_Income&apos;&#13;&#10;ELSEIF  [PatientIncome] &gt;= 100001 AND [PatientIncome] &lt;= 150000 THEN &apos;High_Income&apos;&#13;&#10;END' />
            </column>
            <column caption='Claim Amount' datatype='real' name='[ClaimAmount]' role='measure' type='quantitative' />
            <column caption='Patient Age' datatype='integer' name='[PatientAge]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Patient Income' datatype='real' name='[PatientIncome]' role='dimension' type='ordinal' />
            <column-instance column='[ClaimAmount]' derivation='Avg' name='[avg:ClaimAmount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1241404985065472]' derivation='None' name='[none:Calculation_1241404985065472:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1241404987092993]' derivation='None' name='[none:Calculation_1241404987092993:nk]' pivot='key' type='nominal' />
